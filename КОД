import pandas as pd
import numpy as np  # Импорт перенесен в начало

# 1. Загрузка данных
data = pd.read_csv('/home/user/2025/203C/Нейросеть/StudentsPerformance.csv')

# 2. Кодирование категориальных признаков
gender_map = {'female':0, 'male':1}
lunch_map = {'free/reduced':0,'standard':1}
test_preparation_course_map = {'none':0,'completed':1}

data['gender'] = data['gender'].map(gender_map)
data['lunch'] = data['lunch'].map(lunch_map)
data['test preparation course'] = data['test preparation course'].map(test_preparation_course_map)

# 3. Формирование X и y
# ИЗМЕНЕНИЕ: Добавлен признак 'reading score'
X = data[['gender', 'lunch', 'test preparation course', 'reading score']]
y = data[['math score']]

# 4. Нормализация
from sklearn.preprocessing import MinMaxScaler
scaler_X = MinMaxScaler()
scaler_y = MinMaxScaler()

X = scaler_X.fit_transform(X)
y = scaler_y.fit_transform(y)

# 5. Разделение на выборки
from sklearn.model_selection import train_test_split
X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.1, random_state=42)

# 6. Функция ошибки
def MSE(predictions, targets):
    return np.mean((predictions - targets)**2)

# 7. Класс нейросети
class Network(object):
    def __init__(self, input_dim, hidden_dim, output_dim, learning_rate):
        self.input_dim = input_dim
        self.hidden_dim = hidden_dim
        self.output_dim = output_dim
        self.learning_rate = learning_rate
        
        # Инициализация весов
        self.weights_0_1 = np.random.normal(0.0, 1.0, (hidden_dim, input_dim))
        self.weights_1_2 = np.random.normal(0.0, 1.0, (output_dim, hidden_dim))

    def sigmoid(self, x):
        return 1 / (1 + np.exp(-x))

    def sigmoid_derivative(self, x):
        return x * (1 - x)

    def forward(self, inputs):
        self.inputs_1 = np.dot(self.weights_0_1, inputs)
        self.outputs_1 = self.sigmoid(self.inputs_1)
        
        self.inputs_2 = np.dot(self.weights_1_2, self.outputs_1)
        self.outputs_2 = self.sigmoid(self.inputs_2)
        
        return self.outputs_2

    def backward(self, inputs, expected):
        output = self.forward(inputs)
        
        error_layer_2 = output - expected
        delta_layer_2 = error_layer_2 * self.sigmoid_derivative(output)
        self.weights_1_2 -= self.learning_rate * np.dot(delta_layer_2, self.outputs_1.T)
        
        error_layer_1 = np.dot(self.weights_1_2.T, delta_layer_2)
        delta_layer_1 = error_layer_1 * self.sigmoid_derivative(self.outputs_1)
        self.weights_0_1 -= self.learning_rate * np.dot(delta_layer_1, inputs.T)

# 8. Обучение
epochs = 1000
learning_rate = 0.1

# ИЗМЕНЕНИЕ: input_dim теперь 4 (было 3)
network = Network(4, 2, 1, learning_rate=learning_rate)

for epoch in range(epochs):
    total_loss = 0
    
    for i in range(len(X_train)):
        inputs = X_train[i].reshape(-1, 1)
        target = y_train[i].reshape(-1, 1)
        network.backward(inputs, target)
    
    # Расчет ошибки на обучении
    train_predictions = []
    for i in range(len(X_train)):
        inputs = X_train[i].reshape(-1, 1)
        pred = network.forward(inputs)
        train_predictions.append(pred[0][0])
    
    train_predictions = np.array(train_predictions).reshape(-1, 1)
    train_loss = MSE(train_predictions, y_train)
    
    if epoch % 100 == 0:
        print(f"Эпоха {epoch:4d} | Ошибка (MSE): {train_loss:.6f}")

print("\n✅ Обучение завершено!")

# 9. Тестирование
test_predictions = []
for i in range(len(X_test)):
    inputs = X_test[i].reshape(-1, 1)
    pred = network.forward(inputs)
    test_predictions.append(pred[0][0])

test_predictions = np.array(test_predictions).reshape(-1, 1)
test_loss = MSE(test_predictions, y_test)

print(f"\n📊 Итоговые результаты:")
print(f"Ошибка на обучении (MSE): {train_loss:.6f}")
print(f"Ошибка на тесте (MSE): {test_loss:.6f}")

# 10. Инверсия нормализации для примеров
y_test_real = scaler_y.inverse_transform(y_test)
pred_test_real = scaler_y.inverse_transform(test_predictions)

print(f"\n🔍 Примеры прогнозов (реальные оценки):")
for i in range(5):
    print(f"Факт: {y_test_real[i][0]:.1f} | Прогноз: {pred_test_real[i][0]:.1f}")
